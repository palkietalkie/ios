          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bahasa yang ingin Anda kuasai untuk berbicara."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह भाषा जिसे आप बोलना सीखना चाहते हैं।"
          }
        }
      }
    },
    "Their function or relationship to you (coach, friend, prosecutor). Goes into the prompt.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたとの役割や関係（コーチ、友人、検察官など）。プロンプトに反映されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "他们对你的角色或关系（教练、朋友、检察官）。会写入提示词。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "他們對你的角色或關係（教練、朋友、檢察官）。會寫入提示詞。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신과의 역할이나 관계(코치, 친구, 검사). 프롬프트에 반영됩니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su función o relación contigo (entrenador, amigo, fiscal). Se incluye en el prompt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Função ou relação com você (treinador, amigo, promotor). Vai para o prompt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Leur rôle ou relation avec vous (coach, ami, procureur). Intégré au prompt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Rolle oder Beziehung zu dir (Coach, Freund, Ankläger). Fließt in den Prompt ein."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vai trò hoặc quan hệ với bạn (huấn luyện viên, bạn bè, công tố viên). Đưa vào prompt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Peran atau hubungan dengan Anda (pelatih, teman, jaksa). Masuk ke prompt."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके साथ उनकी भूमिका या रिश्ता (कोच, दोस्त, अभियोजक)। प्रॉम्प्ट में जाता है।"
          }
        }
      }
    },
    "Their life context: where they're from, what they've done. Shapes how they think.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その人物の背景（出身や経歴）。考え方に影響します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "他们的生活背景、来自哪里、做过什么。影响其思维方式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "他們的生活背景、來自哪裡、做過什麼。影響其思維方式。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인물의 삶의 배경、출신과 경력. 사고방식에 영향을 줍니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su contexto vital: de dónde es, qué ha hecho. Moldea su forma de pensar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O contexto de vida, de onde vem, o que fez. Molda como pensa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son contexte de vie, d'où il vient, ce qu'il a fait. Façonne sa pensée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Lebenshintergrund – Herkunft und Werdegang. Prägt ihr Denken."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bối cảnh cuộc sống, quê quán, đã làm gì. Định hình cách họ nghĩ."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Latar hidup, asal dan pengalaman. Membentuk cara berpikirnya."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उनका जीवन संदर्भ, कहाँ से हैं, क्या किया है। उनकी सोच को आकार देता है।"
          }
        }
      }
    },
    "Tip": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヒント"
