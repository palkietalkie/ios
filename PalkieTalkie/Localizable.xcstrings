    "Speed and turn-taking habits — pick a pace, write your own, or both.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "話す速さやターンの取り方。ペースを選ぶか、自由に書くか、両方。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语速和轮流交谈习惯 — 选择节奏、自己写,或两者皆可。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語速和輪流對話習慣 — 選擇節奏、自己寫,或兩者皆可。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "말의 속도와 차례 잡기 — 페이스를 고르거나, 직접 적거나, 둘 다 가능합니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Velocidad y hábitos de turnos — elige un ritmo, escríbelo tú, o ambos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Velocidade e hábitos de troca de turnos — escolha um ritmo, escreva o seu, ou ambos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vitesse et habitudes de prise de parole — choisissez un rythme, écrivez le vôtre, ou les deux."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempo und Sprecherwechsel-Gewohnheiten — wähle ein Tempo, schreibe selbst, oder beides."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tốc độ và thói quen luân phiên — chọn nhịp, tự viết, hoặc cả hai."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kecepatan dan kebiasaan giliran bicara — pilih tempo, tulis sendiri, atau keduanya."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गति और बारी लेने की आदतें — एक गति चुनें, अपनी लिखें, या दोनों।"
          }
        }
      }
    },
