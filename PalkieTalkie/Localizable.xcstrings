    "How fast should your tutor speak?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チューターの話す速さは？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导师说话该多快？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "導師說話該多快？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "튜터가 얼마나 빠르게 말할까요?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué tan rápido debe hablar tu tutor?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Com que rapidez seu tutor deve falar?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À quelle vitesse votre tuteur doit-il parler ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie schnell soll dein Tutor sprechen?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gia sư nên nói nhanh đến mức nào?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seberapa cepat tutormu sebaiknya berbicara?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका ट्यूटर कितनी तेज़ बोले?"
          }
        }
      }
    },
    "How it's measured": {
      "localizations": {
