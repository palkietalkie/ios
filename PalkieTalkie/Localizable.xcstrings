    "Connection lost. Reconnecting.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続が切れました。再接続しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接已断开,正在重新连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "連線已中斷,正在重新連線。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연결이 끊겼습니다. 다시 연결하는 중입니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conexión perdida. Reconectando."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conexão perdida. Reconectando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connexion perdue. Reconnexion en cours."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindung verloren. Verbindung wird wiederhergestellt."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mất kết nối. Đang kết nối lại."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Koneksi terputus. Menyambungkan kembali."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कनेक्शन टूट गया। फिर से कनेक्ट किया जा रहा है।"
          }
        }
      }
    },
    "That's your free practice for today. Come back tomorrow, I'll be here!": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本日の無料分はここまで！また明日も来てね。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天的免费练习就到这里啦！明天再来吧，我等你！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "今天的免費練習就到這裡啦！明天再來吧，我等你！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 무료 연습은 여기까지예요! 내일 또 와요, 기다릴게요!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso es tu práctica gratis de hoy. ¡Vuelve mañana, aquí te espero!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa foi sua prática grátis de hoje. Volte amanhã, vou estar aqui!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est ta pratique gratuite pour aujourd'hui. Reviens demain, je serai là !"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das war deine kostenlose Übung für heute. Komm morgen wieder, ich bin da!"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phần luyện tập miễn phí hôm nay đến đây thôi! Mai quay lại nhé, mình đợi bạn!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Latihan gratismu untuk hari ini sampai di sini! Sampai jumpa besok, ya!"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आज की मुफ़्त प्रैक्टिस यहीं तक! कल फिर आना, मैं यहीं हूँ!"
          }
        }
      }
    },
    "That's your free practice for this week. Come back Monday, I'll be here!": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今週の無料分はここまで！また来週も来てね。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这周的免费练习就到这里啦！周一再来吧，我等你！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這週的免費練習就到這裡啦！週一再來吧，我等你！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이번 주 무료 연습은 여기까지예요! 월요일에 또 와요, 기다릴게요!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso es tu práctica gratis de esta semana. ¡Vuelve el lunes, aquí te espero!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa foi sua prática grátis desta semana. Volte na segunda, vou estar aqui!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est ta pratique gratuite pour cette semaine. Reviens lundi, je serai là !"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das war deine kostenlose Übung für diese Woche. Komm am Montag wieder, ich bin da!"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phần luyện tập miễn phí tuần này đến đây thôi! Thứ Hai quay lại nhé, mình đợi bạn!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Latihan gratismu untuk minggu ini sampai di sini! Sampai jumpa Senin, ya!"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस हफ़्ते की मुफ़्त प्रैक्टिस यहीं तक! सोमवार को फिर आना, मैं यहीं हूँ!"
          }
        }
      }
    },
    "That's your free practice for today. Come back tomorrow, or go unlimited anytime.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本日の無料分はここまで！また明日も来てね。もっと話したいなら、いつでもアップグレードできるよ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天的免费练习就到这里啦！明天再来吧，或者升级，随时畅聊。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "今天的免費練習就到這裡啦！明天再來吧，或者升級，隨時暢聊。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 무료 연습은 여기까지예요! 내일 또 와요. 더 하고 싶으면 언제든 업그레이드해요!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso es tu práctica gratis de hoy. Vuelve mañana, o hazte ilimitado cuando quieras."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Essa foi sua prática grátis de hoje. Volte amanhã, ou vá ilimitado quando quiser."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C'est ta pratique gratuite pour aujourd'hui. Reviens demain, ou passe en illimité quand tu veux."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das war deine kostenlose Übung für heute. Komm morgen wieder, oder hol dir jederzeit Unbegrenzt."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phần luyện tập miễn phí hôm nay đến đây thôi! Mai quay lại nhé, hoặc nâng cấp để trò chuyện thỏa thích bất cứ lúc nào."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Latihan gratismu untuk hari ini sampai di sini! Sampai jumpa besok, atau buka akses tanpa batas kapan saja."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आज की मुफ़्त प्रैक्टिस यहीं तक! कल फिर आना, या जब चाहो अनलिमिटेड पाओ।"
          }
        }
      }
    },
