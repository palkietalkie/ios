    "Multi-word native expressions you've used (e.g., \"give it a shot\", \"figure out\").": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたが使ったネイティブの複数語からなる表現（例：「give it a shot」「figure out」）。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你使用过的由多个单词组成的地道表达（例如 \"give it a shot\"、\"figure out\"）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你使用過的由多個單字組成的道地表達（例如 \"give it a shot\"、\"figure out\"）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신이 사용한 여러 단어로 된 원어민 표현(예: \"give it a shot\", \"figure out\")."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Expresiones nativas de varias palabras que has usado (p. ej., \"give it a shot\", \"figure out\")."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Expressões nativas de várias palavras que você usou (por ex., \"give it a shot\", \"figure out\")."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Expressions natives de plusieurs mots que vous avez utilisées (p. ex., \"give it a shot\", \"figure out\")."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mehrwortige muttersprachliche Ausdrücke, die du verwendet hast (z. B. \"give it a shot\", \"figure out\")."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các cách diễn đạt bản ngữ gồm nhiều từ mà bạn đã dùng (ví dụ: \"give it a shot\", \"figure out\")."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ungkapan asli yang terdiri dari beberapa kata yang sudah kamu gunakan (mis., \"give it a shot\", \"figure out\")."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके द्वारा इस्तेमाल किए गए कई शब्दों वाले नेटिव अभिव्यक्ति (जैसे, \"give it a shot\", \"figure out\")।"
          }
        }
      }
    },
