    "Library preview text. Not sent to the AI.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリのプレビュー用テキストです。AIには送信されません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "资料库预览文字，不会发送给 AI。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "資料庫預覽文字，不會傳送給 AI。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "라이브러리 미리보기 텍스트입니다. AI로 전송되지 않습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Texto de vista previa de la biblioteca. No se envía a la IA."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Texto de prévia da biblioteca. Não é enviado à IA."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Texte d'aperçu de la bibliothèque. Non envoyé à l'IA."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vorschautext der Bibliothek. Wird nicht an die KI gesendet."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Văn bản xem trước trong thư viện. Không gửi cho AI."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Teks pratinjau pustaka. Tidak dikirim ke AI."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लाइब्रेरी पूर्वावलोकन टेक्स्ट. AI को नहीं भेजा जाता।"
          }
        }
      }
    },
    "Listen, then reply out loud whenever you're ready.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "聞いて、準備ができたら声に出して返事しましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先听，准备好了就大声回应。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "先聽，準備好了就大聲回應。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "듣고 나서 준비되면 소리 내어 대답하세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escucha y responde en voz alta cuando estés listo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouça e responda em voz alta quando estiver pronto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Écoutez, puis répondez à voix haute quand vous êtes prêt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hör zu und antworte laut, wenn du bereit bist."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hãy lắng nghe, rồi trả lời thành tiếng khi bạn sẵn sàng."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dengarkan, lalu jawab dengan suara saat kamu siap."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुनिए, फिर तैयार होने पर ज़ोर से जवाब दीजिए।"
          }
        }
      }
    },
