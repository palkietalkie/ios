            "value": "想掌握哪些口音？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "想掌握哪些口音？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어떤 악센트를 익히고 싶나요?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué acentos?"
