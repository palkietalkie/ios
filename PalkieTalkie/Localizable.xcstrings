          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的程度如何？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실력이 어느 정도인가요?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cuál es tu nivel?"
          }
        },
        "pt-BR": {
