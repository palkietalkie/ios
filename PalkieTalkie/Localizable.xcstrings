            "value": "Palkie Talkie의 표시 언어입니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El idioma en que se muestran las pantallas de Palkie Talkie."
          }
        },
        "pt-BR": {
