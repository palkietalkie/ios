    "Voice fluency. Real personalities. No drills.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "話せる流暢さを。本物のキャラクター。ドリルなし。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "口语流利。真实人格。无需机械训练。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "口語流利。真實人格。無需機械訓練。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "말할 수 있는 유창함. 진짜 캐릭터. 반복 훈련 없음."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fluidez al hablar. Personalidades reales. Sin ejercicios."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fluência na fala. Personalidades reais. Sem repetições."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fluidité à l'oral. Vraies personnalités. Pas d'exercices."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprachflüssigkeit. Echte Persönlichkeiten. Keine Drills."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lưu loát khi nói. Tính cách thật. Không bài tập máy móc."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kelancaran bicara. Kepribadian nyata. Tanpa latihan kaku."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बोलने में प्रवाह। असली व्यक्तित्व। कोई ड्रिल नहीं।"
          }
        }
      }
    },
