    "Already paid through Apple but don't see it here? Tap Restore to re-sync.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleで購入済みなのにここに表示されない場合は、「復元」をタップして再同期してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已通过 Apple 付款但未显示？点按“恢复”重新同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已透過 Apple 付款但未顯示？點一下「恢復」重新同步。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple로 결제했지만 여기에 없나요? '복원'을 눌러 다시 동기화하세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Ya pagaste con Apple pero no aparece aquí? Toca Restaurar para volver a sincronizar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já pagou pela Apple mas não aparece aqui? Toque em Restaurar para sincronizar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déjà payé via Apple mais rien ici ? Touchez Restaurer pour resynchroniser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schon über Apple bezahlt, aber nicht hier zu sehen? Tippe auf Wiederherstellen."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã thanh toán qua Apple nhưng không thấy? Chạm Khôi phục để đồng bộ lại."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sudah bayar lewat Apple tapi tidak muncul? Ketuk Pulihkan untuk sinkron ulang."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple से भुगतान कर दिया पर यहाँ नहीं दिख रहा? फिर से सिंक करने के लिए पुनर्स्थापित करें टैप करें।"
          }
        }
      }
    },
