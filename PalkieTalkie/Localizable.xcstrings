    "Talk out loud anytime, your walk, your commute, your kitchen.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いつでも声に出して話せます。散歩中、通勤中、キッチンでも。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "随时随地开口说，散步时、通勤时、在厨房都行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隨時隨地開口說，散步時、通勤時、在廚房都行。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언제든 소리 내어 말하세요. 산책할 때, 출퇴근길에, 부엌에서도."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habla en voz alta cuando quieras: en tu caminata, tu trayecto, tu cocina."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fale em voz alta a qualquer hora: na caminhada, no trajeto, na cozinha."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parlez à voix haute quand vous voulez : en marchant, en trajet, dans la cuisine."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprich jederzeit laut, beim Spaziergang, im Pendelverkehr, in der Küche."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nói thành tiếng bất cứ lúc nào: khi đi bộ, lúc đi làm, trong bếp."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bicara dengan suara kapan saja: saat jalan, saat perjalanan, di dapur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कभी भी ज़ोर से बोलिए, टहलते हुए, सफ़र में, रसोई में।"
          }
        }
      }
    },
