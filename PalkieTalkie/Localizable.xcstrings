            "value": "Was ist deine Muttersprache?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiếng mẹ đẻ của bạn là gì?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apa bahasa ibu Anda?"
          }
        },
        "hi": {
          "stringUnit": {
