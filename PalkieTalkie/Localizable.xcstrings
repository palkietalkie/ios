    "Pace = how fast they talk. Length = how much they say. Pick one or both, or write your own.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペース＝話す速さ。長さ＝話す量。どちらか、または両方を選ぶか、自由に入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语速＝说话快慢。长度＝说话多少。选其一或两者，也可自行填写。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語速＝說話快慢。長度＝說話多寡。擇一或兩者，也可自行填寫。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "속도＝말하는 빠르기. 길이＝말하는 양. 하나 또는 둘 다 선택하거나 직접 입력하세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritmo = qué tan rápido habla. Longitud = cuánto dice. Elige uno, ambos o escribe el tuyo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritmo = velocidade da fala. Comprimento = quanto fala. Escolha um, ambos ou escreva o seu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rythme = vitesse de parole. Longueur = quantité dite. Choisissez l'un, les deux ou le vôtre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempo = Sprechgeschwindigkeit. Länge = Redemenge. Wähle eins, beides oder schreibe selbst."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhịp = nói nhanh chậm. Độ dài = nói nhiều ít. Chọn một, cả hai hoặc tự viết."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempo = seberapa cepat bicara. Panjang = seberapa banyak. Pilih satu, keduanya, atau tulis sendiri."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गति = कितनी तेज़ बोलते हैं। लंबाई = कितना बोलते हैं। एक या दोनों चुनें, या स्वयं लिखें।"
          }
        }
      }
    },
