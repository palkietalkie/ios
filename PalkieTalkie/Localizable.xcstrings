            "value": "जो उच्चारण आप अभ्यास करना चाहते हैं"
          }
        }
      }
    },
    "A few quick details so the AI knows how to talk to you.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AIがあなたに合わせて話せるよう、少しだけ教えてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "简单填写几项,让AI知道如何与您交谈。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "簡單填寫幾項,讓AI知道如何與您交談。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AI가 당신에게 맞춰 대화할 수 있도록 몇 가지만 알려주세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algunos datos rápidos para que la IA sepa cómo hablarte."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Algumas informações rápidas para a IA saber como falar com você."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelques détails rapides pour que l'IA sache comment vous parler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein paar Angaben, damit die KI weiß, wie sie mit dir reden soll."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vài thông tin nhanh để AI biết cách nói chuyện với bạn."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Beberapa detail singkat agar AI tahu cara berbicara dengan Anda."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ त्वरित विवरण ताकि AI जान सके कि आपसे कैसे बात करनी है।"
          }
        }
      }
    },
