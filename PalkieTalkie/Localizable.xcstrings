    "Drives pacing and word choice indirectly. Free text.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペースや言葉選びに間接的に影響します。自由記述。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "间接影响节奏和措辞。自由文本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "間接影響節奏和措辭。自由文字。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "페이스와 단어 선택에 간접적으로 영향. 자유 입력."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Influye indirectamente en el ritmo y la elección de palabras. Texto libre."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Influencia indiretamente o ritmo e a escolha de palavras. Texto livre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Influence indirectement le rythme et le choix des mots. Texte libre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beeinflusst Tempo und Wortwahl indirekt. Freitext."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ảnh hưởng gián tiếp đến nhịp độ và lựa chọn từ. Văn bản tự do."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Memengaruhi tempo dan pilihan kata secara tidak langsung. Teks bebas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गति और शब्द चयन को अप्रत्यक्ष रूप से प्रभावित करता है। फ्री टेक्स्ट।"
          }
        }
      }
    },
