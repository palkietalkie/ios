    "Based on how much you said compared with the AI.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたとAIがそれぞれ話した量をもとにしています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据你和 AI 各自说了多少来计算。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "根據你和 AI 各自說了多少來計算。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신과 AI가 각각 얼마나 말했는지를 기준으로 합니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se basa en cuánto hablaste tú frente a la IA."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Baseado em quanto você falou em relação à IA."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Basé sur ce que vous avez dit par rapport à l’IA."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Basiert darauf, wie viel du im Vergleich zur KI gesagt hast."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dựa trên việc bạn nói nhiều bao nhiêu so với AI."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Berdasarkan seberapa banyak kamu bicara dibanding AI."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने AI की तुलना में कितना कहा, उसके आधार पर।"
          }
        }
      }
    },
