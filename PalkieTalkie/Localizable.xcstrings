    "Pick a style, write your own, or both.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スタイルを選ぶか、自由に記述するか、両方でも。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择风格、自己写,或两者皆可。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇風格、自己寫,或兩者皆可。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스타일을 고르거나, 직접 적거나, 둘 다 가능합니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un estilo, escríbelo tú, o ambos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um estilo, escreva o seu, ou ambos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un style, écrivez le vôtre, ou les deux."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle einen Stil, schreibe selbst, oder beides."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn một phong cách, tự viết, hoặc cả hai."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih gaya, tulis sendiri, atau keduanya."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक शैली चुनें, अपनी लिखें, या दोनों।"
          }
        }
      }
    },
    "Pick a tutor with real personality, or make your own.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "個性豊かなチューターを選ぶか、自分だけのチューターを作りましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "挑一个有真实个性的导师，或者打造你自己的。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "挑一個有真實個性的導師，或者打造你自己的。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "개성 있는 튜터를 고르거나, 나만의 튜터를 만들어 보세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un tutor con personalidad real, o crea el tuyo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um tutor com personalidade real, ou crie o seu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un tuteur avec une vraie personnalité, ou créez le vôtre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle einen Tutor mit echter Persönlichkeit, oder erstelle deinen eigenen."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn một gia sư có cá tính thật, hoặc tự tạo gia sư của riêng bạn."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih tutor dengan kepribadian sungguhan, atau buat milikmu sendiri."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "असली व्यक्तित्व वाला ट्यूटर चुनें, या अपना खुद का बनाएं।"
          }
        }
      }
    },
