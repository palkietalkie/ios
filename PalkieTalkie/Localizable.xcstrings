    "You can change this anytime later.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "後からいつでも変更できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "以后随时可以更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "之後隨時可以更改。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "나중에 언제든 바꿀 수 있어요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes cambiarlo cuando quieras más tarde."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode mudar isso quando quiser depois."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pourrez le modifier à tout moment plus tard."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst das später jederzeit ändern."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có thể thay đổi bất cứ lúc nào sau này."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu bisa mengubah ini kapan saja nanti."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप इसे बाद में कभी भी बदल सकते हैं।"
          }
        }
      }
    },
    "You decide. Change either at any time in More → Privacy & Data.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたが決めます。いつでも「その他 → プライバシーとデータ」で変更できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "由您决定。随时可在“更多 → 隐私与数据”中更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "由您決定。隨時可在「更多 → 隱私與資料」中更改。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신이 결정합니다. 언제든 \"더보기 → 개인정보 및 데이터\"에서 변경할 수 있습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tú decides. Cambia cualquiera de los dos en Más → Privacidad y datos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você decide. Altere a qualquer momento em Mais → Privacidade e Dados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À vous de décider. Modifiez à tout moment dans Plus → Confidentialité et données."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du entscheidest. Ändere jederzeit unter Mehr → Datenschutz & Daten."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn quyết định. Thay đổi bất kỳ lúc nào trong Thêm → Quyền riêng tư & dữ liệu."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda yang memutuskan. Ubah kapan saja di Lainnya → Privasi & Data."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप तय करें। कभी भी \"और → गोपनीयता और डेटा\" में बदलें।"
          }
        }
      }
    },
