    "Your total words divided by the time you spent speaking.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "話した単語量を、あなたが話していた時間で割って求めます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用你说的总词数除以你说话的时间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用你說的總詞數除以你說話的時間。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신이 말한 전체 단어 수를 말한 시간으로 나눕니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus palabras totales divididas entre el tiempo que pasaste hablando."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O total das suas palavras dividido pelo tempo que você passou falando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre nombre total de mots divisé par le temps passé à parler."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Gesamtzahl an Wörtern geteilt durch die Zeit, die du gesprochen hast."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tổng số từ của bạn chia cho thời gian bạn đã nói."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Total katamu dibagi dengan waktu yang kamu habiskan untuk berbicara."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके कुल शब्दों को आपके बोलने में बिताए समय से भाग देकर।"
          }
        }
      }
    },
    "Your tutor mixes these in so you hear natural variety. Pick one or more.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チューターがこれらを織り交ぜて、自然なバリエーションを聞けます。1つ以上選んでください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导师会穿插使用，让你听到自然的多样口音。选择一个或多个。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "導師會穿插使用，讓你聽到自然的多樣口音。選擇一個或多個。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "튜터가 이를 섞어 자연스러운 다양성을 들려줍니다. 하나 이상 선택하세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu tutor los combina para que escuches variedad natural. Elige uno o más."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tutor mistura tudo para você ouvir variedade natural. Escolha um ou mais."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre tuteur les mélange pour une variété naturelle. Choisissez-en un ou plusieurs."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Tutor mischt sie für natürliche Vielfalt. Wähle einen oder mehrere."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gia sư kết hợp chúng để bạn nghe sự đa dạng tự nhiên. Chọn một hoặc nhiều."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutor memadukannya agar Anda mendengar variasi alami. Pilih satu atau lebih."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ट्यूटर इन्हें मिलाता है ताकि आप स्वाभाविक विविधता सुनें। एक या अधिक चुनें।"
          }
        }
      }
    },
    "Your tutor speaks first, you don't need to say anything to begin.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チューターから話しかけます。始めるのに何も言う必要はありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导师会先开口，你不用先说话就能开始。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "導師會先開口，你不用先說話就能開始。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "튜터가 먼저 말을 걸어요. 시작하려고 먼저 말할 필요는 없어요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu tutor habla primero; no necesitas decir nada para empezar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu tutor fala primeiro; você não precisa dizer nada para começar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre tuteur parle en premier ; vous n'avez rien à dire pour commencer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Tutor spricht zuerst, du musst zum Start nichts sagen."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gia sư sẽ nói trước; bạn không cần nói gì để bắt đầu."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutormu bicara lebih dulu; kamu tak perlu berkata apa pun untuk mulai."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका ट्यूटर पहले बोलता है; शुरू करने के लिए आपको कुछ कहने की ज़रूरत नहीं।"
          }
        }
      }
    },
    "Your tutor uses your name in conversation, the way a friend would.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "友だちのように、会話の中であなたの名前を呼びます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导师会像朋友一样，在对话中称呼你的名字。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "導師會像朋友一樣，在對話中稱呼你的名字。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "튜터가 친구처럼 대화 중에 당신의 이름을 불러요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu tutor usará tu nombre en la conversación, como lo haría un amigo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu tutor vai usar seu nome na conversa, como um amigo faria."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre tuteur utilisera votre prénom dans la conversation, comme le ferait un ami."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Tutor spricht dich im Gespräch mit deinem Namen an, wie es ein Freund tun würde."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gia sư sẽ gọi tên bạn trong cuộc trò chuyện, như một người bạn."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutor Anda akan menyebut nama Anda dalam percakapan, seperti seorang teman."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका ट्यूटर बातचीत में आपका नाम लेगा, जैसे कोई दोस्त लेता है।"
          }
        }
      }
    },
