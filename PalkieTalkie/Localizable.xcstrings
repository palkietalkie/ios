    "Measured from your voice on your device. We track your lowest and highest pitch in each conversation.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末で、あなたの声から測定します。セッションごとに、いちばん低い声と高い声を記録します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的设备上根据你的声音测量。我们记录你每次对话中最低和最高的音高。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在你的裝置上根據你的聲音測量。我們記錄你每次對話中最低和最高的音高。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기에서 당신의 목소리로 측정합니다. 대화마다 가장 낮은 음과 높은 음을 기록합니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se mide desde tu voz en tu dispositivo. Registramos tu tono más bajo y más alto en cada conversación."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Medido pela sua voz no seu dispositivo. Registramos seu tom mais grave e mais agudo em cada conversa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesuré à partir de votre voix sur votre appareil. Nous suivons votre note la plus basse et la plus haute à chaque conversation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wird aus deiner Stimme auf deinem Gerät gemessen. Wir erfassen deine tiefste und höchste Tonlage in jedem Gespräch."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Được đo từ giọng nói của bạn trên thiết bị. Chúng tôi ghi lại cao độ thấp nhất và cao nhất trong mỗi cuộc trò chuyện."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Diukur dari suaramu di perangkatmu. Kami mencatat nada terendah dan tertinggimu di setiap percakapan."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके डिवाइस पर आपकी आवाज़ से मापा जाता है। हर बातचीत में आपकी सबसे नीची और सबसे ऊंची पिच दर्ज करते हैं।"
          }
        }
      }
    },
