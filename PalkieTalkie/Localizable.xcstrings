        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका स्तर क्या है?"
          }
        }
      }
    },
    "What's your native language?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "母国語は何ですか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的母语是什么？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的母語是什麼？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모국어가 무엇인가요?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cuál es tu idioma nativo?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Qual é o seu idioma nativo?"
          }
        },
        "fr": {
          "stringUnit": {
