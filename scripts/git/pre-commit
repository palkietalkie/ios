#!/usr/bin/env bash
# Pre-commit hook for palkietalkie/ios.
# Installed by `scripts/setup.sh` via `git config core.hooksPath scripts/git`.
set -e

cd "$(git rev-parse --show-toplevel)"

# Refuse `git commit <pathspec>`. When git assembles a partial commit from a working-tree pathspec, it routes the hook through a temp index (e.g. `.git/next-index-12345`) instead of `.git/index`. That bypasses whatever was staged AND quietly picks up unstaged hunks in the named files — a footgun in multi-session workflows.
if [ -n "$GIT_INDEX_FILE" ] && [ "$(basename "$GIT_INDEX_FILE")" != "index" ]; then
	echo "pre-commit: REFUSED — 'git commit <pathspec>' detected (GIT_INDEX_FILE=$GIT_INDEX_FILE)." >&2
	echo "  This snapshots the working tree of those paths and bypasses the staging boundary." >&2
	echo "  Stage explicitly then commit:  git add <files> && git commit -m '...'" >&2
	exit 1
fi

# Block direct commits to main — feature work always lives on a branch.
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ "$CURRENT_BRANCH" = "main" ]; then
	echo "[pre-commit] don't commit directly to main — branch off first" >&2
	exit 1
fi

# Fast-forward local main from origin so it stays in sync (silent on offline / no remote).
git fetch --quiet origin main:main 2>/dev/null || true

require() {
	local tool=$1 install=$2
	if ! command -v "$tool" >/dev/null 2>&1; then
		echo "[pre-commit] missing $tool. Install: $install" >&2
		exit 1
	fi
}

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# Markdown lint (staged files only — markdownlint walks the directory otherwise).
MD_STAGED=$(echo "$STAGED" | grep -E "\.md$" || true)
if [ -n "$MD_STAGED" ]; then
	require markdownlint "brew install markdownlint-cli"
	echo "[pre-commit] markdownlint..."
	echo "$MD_STAGED" | xargs markdownlint
fi

# Shell format (auto-fix) + lint (fail on violations).
SH_STAGED=$(echo "$STAGED" | grep -E "\.sh$" || true)
if [ -n "$SH_STAGED" ]; then
	require shfmt "brew install shfmt"
	require shellcheck "brew install shellcheck"

	echo "[pre-commit] shfmt (auto-fix)..."
	echo "$SH_STAGED" | xargs shfmt -w
	echo "$SH_STAGED" | xargs git add

	echo "[pre-commit] shellcheck..."
	echo "$SH_STAGED" | xargs shellcheck
fi

# Regenerate Swift Codable types from the backend's OpenAPI spec — only if a backend is reachable. Skip silently otherwise (most pre-commit runs happen without the backend up); CI regenerates explicitly.
OPENAPI_URL="${OPENAPI_URL:-http://localhost:8000/openapi.json}"
if curl -fsS "$OPENAPI_URL" >/dev/null 2>&1; then
	GENERATED="PalkieTalkie/Generated/APITypes.swift"
	echo "[pre-commit] regenerate $GENERATED from $OPENAPI_URL"
	BEFORE=$(cat "$GENERATED" 2>/dev/null || true)
	./scripts/generate_api_types.py --url "$OPENAPI_URL" --out "$GENERATED" >/dev/null
	swiftformat --quiet "$GENERATED"
	AFTER=$(cat "$GENERATED")
	if [ "$BEFORE" != "$AFTER" ]; then
		echo "[pre-commit] $GENERATED drifted — re-stage it and re-commit" >&2
		exit 1
	fi
fi

require swiftformat "brew install swiftformat"
require swiftlint "brew install swiftlint"

# Swift: auto-format whole repo, then lint strictly. Whole-repo so a stray un-formatted file lingering from another tool can't slip in.
echo "[pre-commit] swiftformat (auto-fix, whole repo)..."
DIRTY_BEFORE=$(git diff --name-only)
swiftformat --quiet .

# Re-stage swiftformat's changes — but ONLY for files that were already staged AND otherwise clean. A file with pre-existing unstaged edits is skipped (re-adding it would fold unreviewed work into the commit); unstaged files are never introduced.
CHANGED=$(git diff --name-only)
if [ -n "$CHANGED" ]; then
	echo "$CHANGED" | while read -r f; do
		echo "$STAGED" | grep -qx "$f" || continue
		echo "$DIRTY_BEFORE" | grep -qx "$f" && continue
		git add "$f" && echo "[pre-commit] re-staged formatter changes in $f"
	done
fi

echo "[pre-commit] swiftlint --strict (whole repo)..."
swiftlint lint --strict --quiet

# Regenerate Xcode project if project.yml changed.
if echo "$STAGED" | grep -qx "project.yml"; then
	require xcodegen "brew install xcodegen"
	echo "[pre-commit] project.yml changed → xcodegen generate"
	xcodegen generate
fi

# Compile sanity (build only, no tests) if any Swift file or project.yml is staged: catch a non-compiling commit fast.
if echo "$STAGED" | grep -qE "(\.swift$|^project\.yml$)"; then
	require xcodebuild "install Xcode"
	echo "[pre-commit] xcodebuild build-for-testing (compile sanity)..."
	xcodebuild \
		-project PalkieTalkie.xcodeproj \
		-scheme PalkieTalkie \
		-destination 'generic/platform=iOS Simulator' \
		CODE_SIGNING_ALLOWED=NO \
		build-for-testing -quiet
fi

# Full end-to-end: deploy backend + Modal to dev, install on connected iPhone, start local website.
# Lives at the parent dir (multi-repo container). Skip the deploy half so commits don't push to dev infra every time; iOS install only.
BOOT_SH="$(git rev-parse --show-toplevel)/../scripts/boot.sh"
if [ -x "$BOOT_SH" ]; then
	echo "[pre-commit] boot.sh --no-deploy --no-ios=0 (install on iPhone)"
	"$BOOT_SH" --no-deploy
fi
