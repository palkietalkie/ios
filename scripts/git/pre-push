#!/usr/bin/env bash
# Pre-push: run the branch-level check that CI enforces, so a red PR never leaves the machine.
#
# The paired-test guard compares the whole branch against origin/main — a branch-level invariant, NOT a per-commit one. It lives here (pre-push), not in pre-commit: in pre-commit it would wrongly reject committing a source file in one commit and its test in the next. Pre-push runs once on the exact state about to become the PR, which mirrors CI (same case-sensitive matching, same script).
set -e

REPO="$(git rev-parse --show-toplevel)"
echo "[pre-push] paired-test guard (same check CI runs)..."
bash "$REPO/scripts/ci/check_test_pair.sh" origin/main
echo "[pre-push] swift file-name PascalCase guard..."
bash "$REPO/scripts/ci/check_swift_pascal_case.sh"
echo "[pre-push] Views/ placement guard (views + view models only)..."
bash "$REPO/scripts/ci/check_view_dir_placement.sh"

# API-types drift gate: the committed Generated/APITypes.swift must match what the backend's live OpenAPI produces, so a backend field change that iOS didn't regenerate for can't ship a silently-broken decode. Generate from the dev backend (always up) into a temp file and diff. Network-unreachable is a warn-skip, not a block — a flaky network shouldn't wedge a push.
echo "[pre-push] API-types codegen drift gate..."
API_OPENAPI_URL="https://palkietalkie-api-dev.fly.dev/openapi.json"
API_TYPES="$REPO/PalkieTalkie/Generated/APITypes.swift"
API_TMP="$(mktemp -t APITypes).swift"
if uv run "$REPO/scripts/generate_api_types.py" --url "$API_OPENAPI_URL" --out "$API_TMP" >/dev/null 2>&1; then
	# The committed file is the generator output AFTER swiftformat (the pre-commit hook formats it). Format the freshly-generated temp the same way before diffing, or formatting-only differences would false-fail this gate forever.
	command -v swiftformat >/dev/null 2>&1 && swiftformat --quiet "$API_TMP" >/dev/null 2>&1 || true
	if ! diff -q "$API_TMP" "$API_TYPES" >/dev/null 2>&1; then
		echo "[pre-push] Generated/APITypes.swift is stale vs the backend OpenAPI." >&2
		echo "[pre-push] Regenerate: uv run scripts/generate_api_types.py --url $API_OPENAPI_URL" >&2
		rm -f "$API_TMP"
		exit 1
	fi
	rm -f "$API_TMP"
else
	echo "[pre-push] WARN: couldn't reach $API_OPENAPI_URL — skipping API-types drift gate" >&2
	rm -f "$API_TMP"
fi

# Branch-level test run + 90 percent line-coverage gate (CI parity). The simulator boot + xctest run is too slow for per-commit.
cd "$REPO"
echo "[pre-push] xcodebuild test + 90 percent line-coverage gate..."
rm -rf /tmp/PalkieTalkiePrePush.xcresult
xcodebuild \
	-project PalkieTalkie.xcodeproj \
	-scheme PalkieTalkie \
	-destination 'platform=iOS Simulator,name=iPhone 17 Pro,OS=latest' \
	-resultBundlePath /tmp/PalkieTalkiePrePush.xcresult \
	-enableCodeCoverage YES \
	CODE_SIGNING_ALLOWED=NO \
	test -quiet
pct=$(xcrun xccov view --report --json /tmp/PalkieTalkiePrePush.xcresult \
	| python3 -c "import json,sys; d=json.loads(sys.stdin.read()); t=next((x for x in d['targets'] if x['name'].startswith('PalkieTalkie.app') or x['name']=='PalkieTalkie'), None); print(round(t['lineCoverage']*100, 2)) if t else (print('NO_TARGET') or exit(1))")
echo "[pre-push] line coverage: ${pct}%"
rm -rf /tmp/PalkieTalkiePrePush.xcresult
awk "BEGIN {exit !(${pct} >= 90)}" || {
	echo "[pre-push] line coverage ${pct}% is below the 90% gate" >&2
	exit 1
}
